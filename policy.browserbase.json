{
  "version": "1.0",
  "baseUrl": "https://api.browserbase.com",
  "policies": [
    {
      "route": "/v1/sessions/*",
      "method": "GET",
      "action": "allow",
      "response_filter": {
        "type": "include_fields",
        "fields": ["id", "projectId", "proxyBytes"]
      }
    }
  ],
  "default_action": "deny"
}
